<%- include('header.ejs');%>
      <main class="dashboard-content">
        <div class="container-fluid px-3 px-lg-4 py-4">
          <div class="page-heading">
            <div class="page-heading-copy">
              <span class="page-icon"><i class="bi bi-file-earmark" aria-hidden="true"></i></span>
              <div>
                <p class="eyebrow mb-1">Starter</p>
                <h1 class="h3 mb-1">Dental Solutions Update</h1>
              </div>
            </div>
          </div>
          <section class="panel mb-3">
                <form action="/admin/dentalsolutions_edit_save/<%=data.did%>" method="post">
                    <label>Title</label>
                    <input type="text"  name="title" value="<%=data.title%>" class="form-control mb-3"/>
                    <label>Description</label>
                    <input  class="form-control mb-4" name="description" value="<%=data.description%>"></input>
                    <button class="btn btn-success">Update</button>
                </form>
                
          </section>
        </div>
      </main>
<%- include('footer.ejs');%>