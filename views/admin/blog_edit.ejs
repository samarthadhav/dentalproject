<%- include('header.ejs');%>
      <main class="dashboard-content">
        <div class="container-fluid px-3 px-lg-4 py-4">
          <div class="page-heading">
            <div class="page-heading-copy">
              <span class="page-icon"><i class="bi bi-file-earmark" aria-hidden="true"></i></span>
              <div>
                <p class="eyebrow mb-1">Starter</p>
                <h1 class="h3 mb-1">Blog Update</h1>
              </div>
            </div>
          </div>
          <section class="panel mb-3">
                <form action="/admin/blog_edit_save/<%=data.bid%>/<%=data.bphoto%>" method="post" enctype="multipart/form-data">
                    <label>Photo</label>
                    <input type="file"  name="bphoto" class="form-control mb-3"/>
                    <img src="/images/<%=data.bphoto%>" height="100px"/>

                    <label>Date</label>
                    <input type="date"  name="bdate" value="<%=data.bdate%>" class="form-control mb-3"/>
                    <label>Title</label>
                    <input type="text"  name="btitle"  value="<%=data.btitle%>" class="form-control mb-3"/>
                    <label>Description</label>
                    <input class="form-control mb-3" name="bdescription" value="<%=data.bdescription%>" ></input>
                    <button class="btn btn-success">Update</button>
                </form>
              
          </section>
        </div>
      </main>
<%- include('footer.ejs');%>