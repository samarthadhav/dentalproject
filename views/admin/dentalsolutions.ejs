<%- include('header.ejs');%>
      <main class="dashboard-content">
        <div class="container-fluid px-3 px-lg-4 py-4">
          <div class="page-heading">
            <div class="page-heading-copy">
              <span class="page-icon"><i class="bi bi-file-earmark" aria-hidden="true"></i></span>
              <div>
                <p class="eyebrow mb-1">Starter</p>
                <h1 class="h3 mb-1">Dental Solutions</h1>
              </div>
            </div>
          </div>
          <section class="panel mb-3">
                <form action="/admin/dentalsolutions_save" method="post">
                    <label>Title</label>
                    <input type="text"  name="title" class="form-control mb-3"/>
                    <label>Description</label>
                    <textarea class="form-control mb-3" name="description" ></textarea>
                    <button class="btn btn-danger">Save</button>
                </form>
                <table class="table table-border mt-5">
                    <tr>
                        <th>Sr No</th>
                        <th>Title</th>
                        <th>Description</th>
                        <th>Status</th>
                    </tr>
                    <% for(var i=0;i<data.length;i++){%>
                        <tr>
                            <th><%=i+1%></th>
                            <th><%=data[i].title%></th>
                            <th><%=data[i].description%></th>
                            <th>
                                <a href="/admin/dentalsolutions_edit/<%=data[i].did%>"><button class="btn btn-danger">Edit</button></a>
                                <a href="/admin/dentalsolutions_delete/<%=data[i].did%>"><button class="btn btn-primary">Delete</button></a>
                            </th>
                        </tr>
                        <%}%>
                </table>
          </section>
        </div>
      </main>
<%- include('footer.ejs');%>